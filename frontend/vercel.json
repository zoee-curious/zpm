{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*powershell.*"
        }
      ],
      "destination": "https://api.zoee.fun/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
